while True:

    genre = input("What genre do you like? (press Q or q to quit)\n")

    if genre.lower() == "q":
        print("Program stopped.")
        break

    age = input("What age restriction?\n")

    language = input("What language do you want?\n")

    animated = input("Animated movie? (Yes/No)\n")

    rating = float(input("Minimum IMDb rating?\n"))

    scored_movies = []

    for movie in movies:

        score = 0

        if movie["genre"].lower() == genre.lower():
            score += 2

        if movie["age"].lower() == age.lower():
            score += 1

        if movie["language"].lower() == language.lower():
            score += 1

        if movie["animated"].lower() == animated.lower():
            score += 1

        if movie["rating"] >= rating:
            score += 2

        scored_movies.append((score, movie))

    # Legger till filmens poeng och information i listan scored_movies.

# Den film som har mest poeng ligger hogst upp i listan eftersom de er sorterade genom vilken som har hogst poeng.
scored_movies.sort(reverse=True, key=lambda x: x[0])

# Sorterar filmerna fran hogst poeng till legst poeng.
print("\nWe recommend these movies:\n")

# Skriver ut en text som visar att programmet ska rekommendera filmer.

# Printar top 3 filmer som fick mest poeng efter fragorna som stelldes.
for i in range(3):

    # Loopar igenom de 3 besta filmerna.

    movie = scored_movies[i][1]

    # Hemtar filmens information fran listan scored_movies.

