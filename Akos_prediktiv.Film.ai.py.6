# Programmet fortsätter att köras tills användaren väljer att avsluta.
while True:

    # Frĺgar användaren vilken genre de föredrar.
    genre = input("What genre do you like?\n")

    # Frĺgar efter önskad ĺldersgräns.
    age = input("What age restriction?\n")

    # Frĺgar vilket sprĺk filmen ska vara pĺ.
    language = input("What language do you want?\n")

    # Frĺgar om användaren vill ha en animerad film eller inte.
    animated = input("Animated movie? (Yes/No)\n")

    # Försöker läsa in användarens minsta önskade IMDb-betyg.
    try:
        rating = float(input("Minimum IMDb rating?\n"))

    # Om användaren inte skriver ett giltigt tal visas ett felmeddelande.
    except ValueError:
        print("Please enter a valid number.")
        continue

    # Lista som ska innehĺlla filmernas poäng och information.
    scored_movies = []

    # Gĺr igenom alla filmer i listan.
    for movie in movies:

        # Hoppar över filmer som har lägre betyg än användaren önskar.
        if movie["rating"] < rating:
            continue

        # Varje film börjar med 0 poäng.
        score = 0

        # Om genren matchar fĺr filmen 2 poäng.
        if movie["genre"].lower() == genre.lower():
            score += 2

        # Om ĺldersgränsen matchar fĺr filmen 1 poäng.
        if movie["age"].lower() == age.lower():
            score += 1

        # Om sprĺket matchar fĺr filmen 1 poäng.
        if movie["language"].lower() == language.lower():
            score += 1

        # Om filmen är animerad eller inte enligt användarens önskemĺl fĺr den 1 poäng.
        if movie["animated"].lower() == animated.lower():
            score += 1

        # Lägger till en liten bonus baserad pĺ IMDb-betyget.
        score += movie["rating"] / 10

        # Sparar filmens poäng tillsammans med filmens information.
        scored_movies.append((score, movie))

    # Sorterar filmerna frĺn högst poäng till lägst poäng.
    scored_movies.sort(reverse=True, key=lambda x: x[0])

    # Om inga filmer matchade användarens krav visas ett meddelande.
    if len(scored_movies) == 0:
        print("\nNo movies matched your search.\n")
        continue

    # Rubrik för rekommendationerna.
    print("\nWe recommend these movies:\n")

    # Hjelp av AI.
    for i, (_, movie) in enumerate(scored_movies[:3], start=1):

        # Skriver ut filmens placering och titel.
        print(f"{i}. {movie['title']}")

        # Skriver ut filmens genre.
        print(f"Genre: {movie['genre']}")

        # Skriver ut filmens ĺldersgräns.
        print(f"Age: {movie['age']}")

        # Skriver ut filmens längd.
        print(f"Runtime: {movie['runtime']}")

        # Skriver ut vilket ĺr filmen släpptes.
        print(f"Year: {movie['year']}")

        # Skriver ut filmens IMDb-betyg.
        print(f"IMDb Rating: {movie['rating']}")

        # Skriver ut filmens sprĺk.
        print(f"Language: {movie['language']}")

        # Skriver ut om filmen är animerad eller inte.
        print(f"Animated: {movie['animated']}")

        # Tom rad för att göra utskriften mer lättläst.
        print()

    # Frĺgar användaren om de vill fĺ fler rekommendationer.
    continue_choice = input("Do you want more movie recommendations? (Yes/No)\n")

    # Om användaren inte svarar "yes" avslutas programmet.
    if continue_choice.lower() != "yes":
        print("Program stopped.")
        break

