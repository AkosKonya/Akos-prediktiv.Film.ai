# Sparar vilken genre anvendaren gillade senast.
preferred_genre = None

# Programmet fortsetter att koras tills anvendaren veljer att avsluta.
while True:

    # Fragar anvendaren vilken genre de foredrar.
    genre = input("What genre do you like?\n")

    # Fragar efter onskad aldersgrens.
    age = input("What age restriction?\n")

    # Fragar vilket sprak filmen ska vara pa.
    language = input("What language do you want?\n")

    # Fragar om anvendaren vill ha en animerad film eller inte.
    animated = input("Animated movie? (Yes/No)\n")

    # Forsoker lesa in anvendarens minsta onskade IMDb-betyg.
    try:
        rating = float(input("Minimum IMDb rating?\n"))

    # Om anvendaren inte skriver ett giltigt tal visas ett felmeddelande, fick hjelp av AI pa denna funktionen.
    except ValueError:
        print("Please enter a valid number.")
        continue

    # Lista som ska innehalla filmernas poeng och information.
    scored_movies = []

    # Gar igenom alla filmer i listan.
    for movie in movies:

        # Hoppar over filmer som har legre betyg en anvendaren onskar.
        if movie["rating"] < rating:
            continue

        # Varje film borjar med 0 poeng.
        score = 0

        # Om genren matchar far filmen 2 poeng.
        if movie["genre"].lower() == genre.lower():
            score += 2

        # Om anvendaren tidigare gillade en film fran samma genre
        # far filmen extra poeng i framtida rekommendationer.
        if preferred_genre and movie["genre"].lower() == preferred_genre.lower():
            score += 1

        # Om aldersgrensen matchar far filmen 1 poeng.
        if movie["age"].lower() == age.lower():
            score += 1

        # Om spraket matchar far filmen 1 poeng.
        if movie["language"].lower() == language.lower():
            score += 1

        # Om filmen er animerad eller inte enligt anvendarens onskemal far den 1 poeng.
        if movie["animated"].lower() == animated.lower():
            score += 1

        # Legger till en liten bonus baserad pa IMDb-betyget.
        score += movie["rating"] / 10

        # Sparar filmens poeng tillsammans med filmens information.
        scored_movies.append((score, movie))

    # Sorterar filmerna fran hogst poeng till legst poeng, fick hjelp fran google.
    scored_movies.sort(reverse=True, key=lambda x: x[0])

    # Om inga filmer matchade anvendarens krav visas ett meddelande.
    if len(scored_movies) == 0:
        print("\nNo movies matched your search.\n")
        continue

    # Rubrik for rekommendationerna.
    print("\nWe recommend these movies:\n")

    # Hjelp av AI.
    for i, (_, movie) in enumerate(scored_movies[:3], start=1):

        # Skriver ut filmens placering och titel.
        print(f"{i}. {movie['title']}")

        # Skriver ut filmens genre.
        print(f"Genre: {movie['genre']}")

        # Skriver ut filmens aldersgrens.
        print(f"Age: {movie['age']}")

        # Skriver ut filmens lengd.
        print(f"Runtime: {movie['runtime']}")

        # Skriver ut vilket ar filmen slepptes.
        print(f"Year: {movie['year']}")

        # Skriver ut filmens IMDb-betyg.
        print(f"IMDb Rating: {movie['rating']}")

        # Skriver ut filmens sprak.
        print(f"Language: {movie['language']}")

        # Skriver ut om filmen er animerad eller inte.
        print(f"Animated: {movie['animated']}")

        # Tom rad for att gora utskriften mer lettlest.
        print()

    # Fragar anvendaren om nagon av rekommendationerna var bra.
    feedback = input(
        "Was any recommendation good? Enter the movie title or press Enter to skip:\n"
    )

    # Om anvendaren skriver in en filmtitel sparas genren.
    if feedback:

        # Gar igenom alla filmer for att hitta filmen anvendaren valde.
        for movie in movies:

            # Om filmtiteln matchar anvendarens svar.
            if movie["title"].lower() == feedback.lower():

                # Sparar filmens genre som preferens.
                preferred_genre = movie["genre"]

                # Bekraftar att feedbacken har tagits emot.
                print(
                    f"Thanks for the feedback! We will recommend more {preferred_genre} movies next time."
                )

                # Avslutar sokningen eftersom filmen hittades.
                break

    # Fragar anvendaren om de vill fa fler rekommendationer.
    continue_choice = input("Do you want more movie recommendations? (Yes/No)\n")

    # Om anvendaren inte svarar "yes" avslutas programmet.
    if continue_choice.lower() != "yes":
        print("Program stopped.")
        break

